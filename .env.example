# -------------------------------------------------------------------------------
# AUTO PUBLISHER - ENVIRONMENT CONFIGURATION TEMPLATE (.env)
# -------------------------------------------------------------------------------

# [SECURITY]
ADMIN_USERNAME=
ADMIN_PASSWORD=
SECRET_KEY=

# Copy this file to '.env' and fill in your actual credentials/paths.
# -------------------------------------------------------------------------------

# [DATABASE]
# Empty by default to use dynamic path resolution relative to app installation.
DB_PATH=

# [TELEGRAM NOTIFICATIONS]
# Get your token from @BotFather and chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# [AI / GOOGLE AI STUDIO]
# Get your key from https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# [INFRASTRUCTURE]
# VERCEL_REDIRECT_URL=https://vercel-redirect-rho-three.vercel.app
# PM2_LOGS_EXTRA_DIRS=/var/log/pm2:/custom/logs

# [SECURITY]
# Secret for syncing cookies between instances
# COOKIE_SYNC_SECRET=change_me_to_something_secure

# [WORKER PERFORMANCE]
# WORKER_TICK_SECONDS=20
# MAX_CONCURRENT_ACCOUNTS=2
# SAFE_MODE=false

# [FACEBOOK / PLAYWRIGHT]
# true = Chromium không mở cửa sổ (PM2/xvfb); Facebook có thể hành xử khác — thử nếu cần
FACEBOOK_PLAYWRIGHT_HEADLESS=false

# [FFMPEG PROCESSING]
# FFMPEG_ENABLED=true
# FFMPEG_PROFILE=reels
# FFMPEG_CRF=28
# FFMPEG_WATERMARK_PATH=content/watermark.png

# [DRM / COPYRIGHT]
# DRM_ENABLED=true
# DRM_WATERMARK_TEXT=z

# [ALERTS]
# ALERT_COOLDOWN_SEC=600
# ALERT_RAM_PCT_THRESHOLD=85
# ALERT_CHROME_PROC_THRESHOLD=20
