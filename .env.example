# -------------------------------------------------------------------------------
# AUTO PUBLISHER - ENVIRONMENT CONFIGURATION TEMPLATE (.env)
# -------------------------------------------------------------------------------
# Copy this file to '.env' and fill in your actual credentials/paths.
# -------------------------------------------------------------------------------

# [DATABASE]
# DB_PATH=/home/vu/toolsauto/data/auto_publisher.db

# [TELEGRAM NOTIFICATIONS]
# Get your token from @BotFather and chat_id from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# [INFRASTRUCTURE]
# Affiliate redirect base (no default in code — set when using hosted /r/{code} links)
# VERCEL_REDIRECT_URL=https://your-redirect.example.com
# TikWM fallback (viral TikTok download); defaults match previous hardcoded behavior
# TIKWM_API_BASE=https://www.tikwm.com/api
# TIKWM_API_TIMEOUT_SEC=15
# TIKWM_VIDEO_DOWNLOAD_TIMEOUT_SEC=60
# PM2_LOGS_EXTRA_DIRS=/var/log/pm2:/custom/logs

# [SECURITY]
# Secret for syncing cookies between instances
# COOKIE_SYNC_SECRET=change_me_to_something_secure

# [WORKER PERFORMANCE]
# WORKER_TICK_SECONDS=20
# MAX_CONCURRENT_ACCOUNTS=2
# SAFE_MODE=false

# [FACEBOOK / PLAYWRIGHT]
# true = Chromium không mở cửa sổ (PM2/xvfb); Facebook có thể hành xử khác — thử nếu cần
FACEBOOK_PLAYWRIGHT_HEADLESS=true

# [FFMPEG PROCESSING]
# FFMPEG_ENABLED=true
# FFMPEG_PROFILE=reels
# FFMPEG_CRF=28
# FFMPEG_WATERMARK_PATH=content/watermark.png

# [DRM / COPYRIGHT]
# DRM_ENABLED=true
# DRM_WATERMARK_TEXT=z

# [ALERTS]
# ALERT_COOLDOWN_SEC=600
# ALERT_RAM_PCT_THRESHOLD=85
# ALERT_CHROME_PROC_THRESHOLD=20
